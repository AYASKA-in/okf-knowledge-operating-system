# EKOS Configuration
DATABASE_URL=postgresql+asyncpg://ekos:ekos@localhost:5432/ekos
DATABASE_URL_SYNC=postgresql+psycopg2://ekos:ekos@localhost:5432/ekos

# Google Cloud / Vertex AI
GCP_PROJECT_ID=your-project-id
GCP_LOCATION=us-central1
VERTEX_AI_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# OKF Storage
OKF_BUNDLE_ROOT=./data/bundles
OKF_DEFAULT_WORKSPACE=default

# Security
JWT_SECRET=change-this-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
JWT_REFRESH_EXPIRY_DAYS=7

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000"]

# AI Model Defaults
INGESTION_MODEL=gemini-1.5-flash-002
CHAT_MODEL=gemini-1.5-pro-002
